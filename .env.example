PORT=3001

# Free test setup via OpenRouter.
# Create a key at https://openrouter.ai/keys and paste it in .env.
LLM_PROVIDER=openrouter
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=openrouter/free
OPENROUTER_API_KEY=

# OpenAI example:
# LLM_PROVIDER=openai
# OPENAI_BASE_URL=
# OPENAI_MODEL=gpt-4.1-mini
# OPENAI_API_KEY=

# Groq example:
# LLM_PROVIDER=groq
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# GROQ_API_KEY=

